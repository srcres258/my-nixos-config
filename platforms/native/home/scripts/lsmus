#!/usr/bin/sh
# @author nate zhou
# @since 2024,2025,2026
# list current playing music with mpc

ARTIST="箚쟽"
TITLE="箚씂"
ALBUM="茶뜖"
icon="箚씂"

if [ $(mpc status '%state%') != "playing" ]; then
    icon="箚씃"
fi

outputs=$(mpc outputs | grep 'is enabled$' | sed -n 's/.*(\([^)]*\)).*/箚뱜 \1/p')

msg=$(mpc --format="$ARTIST %artist%\n$TITLE %title%\n$ALBUM %album% (%date%)" \
    current)
state="[$icon $(mpc status %state%)]"

if [ -n "$msg" ]; then
    echo "$msg"
    if [ "$XDG_SESSION_TYPE" != "tty" ]; then
        [ -z "$msg" ] && title=""
        notify-send -u low -r 188 -t 5000 "$state" "$msg\n$outputs"
    fi
fi
